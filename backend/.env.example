# --- API keys ---
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_MAPS_API_KEY=AIza...

# --- App config ---
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# --- Limits ---
